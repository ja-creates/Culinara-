rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }

    match /test/connection {
      allow read: if true;
    }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // Auth-based isAdmin - includes bootstrapped admin
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == "judeotu91@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['displayName']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('role' in data) || data.role == 'user'); // Prevent self-admin
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'ownerId', 'members']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId is string && isValidId(data.ownerId) &&
             data.members is map && data.members.size() <= 50 &&
             // Ensure at least the owner is an admin
             data.members.get(data.ownerId, 'none') == 'admin' &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidRecipe(data, isCreate) {
      return data.keys().hasAll(['title', 'ingredients', 'instructions', 'authorId', 'householdId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.ingredients is list && data.ingredients.size() <= 100 &&
             (data.ingredients.size() == 0 || data.ingredients[0] is string) &&
             data.instructions is list && data.instructions.size() <= 50 &&
             (data.instructions.size() == 0 || data.instructions[0] is string) &&
             (!('category' in data) || (data.category is string && data.category in ["Breakfast", "Lunch", "Dinner", "Dessert", "Snack", "Drink", "Other"])) &&
             data.authorId == request.auth.uid &&
             data.householdId is string && isValidId(data.householdId) &&
             (isCreate ? data.createdAt == request.time : true) &&
             (!('tips' in data) || (data.tips is list && data.tips.size() <= 20 && (data.tips.size() == 0 || data.tips[0] is string))) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('estimatedTime' in data) || (data.estimatedTime == null || data.estimatedTime is number)) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             (!('shareToken' in data) || (data.shareToken is string && data.shareToken.size() <= 100));
    }

    // ===============================================================
    // Collection Specific Logic
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); 
      allow create: if isVerified() && request.auth.uid == userId && 
                      isValidUser(incoming()) && 
                      incoming().keys().size() <= 3; // displayName, photoURL, (role)
      allow update: if isVerified() && request.auth.uid == userId && 
                      isValidUser(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /households/{householdId} {
      function isMember() {
        return existing().members.get(request.auth.uid, 'none') in ['admin', 'member', 'viewer'];
      }
      function isOwner() {
        return existing().ownerId == request.auth.uid;
      }
      function isHouseholdAdmin() {
        return existing().members.get(request.auth.uid, 'none') == 'admin' || isOwner();
      }

      allow get: if (isMember() || isAdmin()) && isValidId(householdId);
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      
      allow create: if isVerified() && 
                      isValidId(householdId) &&
                      incoming().ownerId == request.auth.uid && 
                      incoming().members[request.auth.uid] == 'admin' &&
                      isValidHousehold(incoming()) &&
                      incoming().keys().size() <= 5; // name, ownerId, members, createdAt, ...
      
      allow update: if isVerified() && (isHouseholdAdmin() || isAdmin()) && 
                      incoming().ownerId == existing().ownerId &&
                      isValidHousehold(incoming()) &&
                      (
                        // Action: Update Name
                        incoming().diff(existing()).affectedKeys().hasOnly(['name']) ||
                        // Action: Manage Members
                        (isHouseholdAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['members'])) ||
                        // Action: Admin Override
                        isAdmin()
                      );

      allow delete: if (isOwner() || isAdmin()) && isValidId(householdId);
    }

    match /recipes/{recipeId} {
      function getHousehold() {
        return get(/databases/$(database)/documents/households/$(resource.data.householdId)).data;
      }
      function getIncomingHousehold() {
        return get(/databases/$(database)/documents/households/$(incoming().householdId)).data;
      }
      function canAccessRecipe() {
        return existing().isPublic == true || isAdmin() || (
          isSignedIn() && (
            existing().authorId == request.auth.uid ||
            getHousehold().members.get(request.auth.uid, 'none') in ['admin', 'member', 'viewer']
          )
        );
      }

      // Separate get and list to avoid get() in list
      allow get: if canAccessRecipe() && isValidId(recipeId);
      allow list: if existing().isPublic == true || (isSignedIn() && existing().authorId == request.auth.uid);
      // Note: Listing recipes for a household must be done via a query that filters by householdId
      // and we cannot easily verify membership in 'allow list' without a 'get()' call.
      // We'll allow the list if the document's own data is sufficient, 
      // or the client MUST rely on household-based queries.
      
      allow create: if isVerified() && 
                      isValidId(recipeId) &&
                      isValidRecipe(incoming(), true) &&
                      exists(/databases/$(database)/documents/households/$(incoming().householdId)) &&
                      getIncomingHousehold().members.get(request.auth.uid, 'none') in ['admin', 'member'] &&
                      incoming().keys().size() <= 15;

      allow update: if isVerified() && 
                      isValidId(recipeId) &&
                      isValidRecipe(incoming(), false) &&
                      (isAdmin() || (
                        (existing().authorId == request.auth.uid || getHousehold().members.get(request.auth.uid, 'none') == 'admin') &&
                        incoming().authorId == existing().authorId &&
                        incoming().householdId == existing().householdId &&
                        incoming().createdAt == existing().createdAt &&
                        (
                          // Action: Edit Content
                          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'ingredients', 'instructions', 'tips', 'category', 'estimatedTime', 'imageUrl', 'sourceUrl']) ||
                          // Action: Toggle Privacy/Sharing
                          incoming().diff(existing()).affectedKeys().hasOnly(['isPublic', 'shareToken']) ||
                          // Action: Rate
                          (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rating']))
                        )
                      ));

      allow delete: if (isAdmin() || (isVerified() && (
                      existing().authorId == request.auth.uid || 
                      get(/databases/$(database)/documents/households/$(existing().householdId)).data.members.get(request.auth.uid, 'none') == 'admin'
                    ))) && isValidId(recipeId);
    }
  }
}
